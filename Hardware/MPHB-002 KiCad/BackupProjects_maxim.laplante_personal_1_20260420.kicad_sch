	(text "Note: 47kΩ resistor in\n place because this is a\n 10V rail. The ADPC\n expects a 5V rail for\n detection. On both \"A\"\n and \" B\" HB\n connections, there is a\n 20k + 33k resistor\n divider to PH_EN_A. \n This presents 3.3V to\n the PH_EN_A pin on the\n RP2350, allowing the \n ADPC to detect the\n connection. There is\n also a shared \n Y-network of 5k, 50k,\n and 9.5k resistors.\n The 9.5k resistors\n should be **removed**!!"
		(exclude_from_sim no)
		(at 168.91 85.8012 0)
		(effects
			(font
				(face "KiCad Font")
				(size 1.8288 1.8288)
			)
			(justify left top)
		)
		(uuid "b8a271a7-6878-4492-9687-0382f5fd6b3c")
	)
	(text "This jumper acts to put the board\nonto a single supply. Do not jumper\nthese pins if using two supplies, as they \nwill short to each other."
		(exclude_from_sim no)
		(at 123.19 162.0012 0)
		(effects
			(font
				(face "KiCad Font")
				(size 1.8288 1.8288)
			)
			(justify left top)
		)
		(uuid "c266a193-efae-4d9b-968b-e75fb63dc6dc")
	)
	(text "BETTER SCHEMATIC RENDITION AVAILABLE IN KICAD AND DOCUMENTATION FOLDERS!"
		(exclude_from_sim no)
		(at 101.6 44.5262 0)
		(effects
