	(text "PH_EN signals are meant\nto connect to open/drain pins.\nThis is input/output low in \nRP2350 software. This allows\nthe MCU to detect a powered,\nconnected MPHB-002 in addition\nto driving the enable pins on \nthat HB's gate drivers."
		(exclude_from_sim no)
		(at 113.03 72.136 0)
		(effects
			(font
				(face "KiCad Font")
				(size 1.524 1.524)
			)
			(justify left top)
		)
		(uuid "c8dcf4ff-1b8d-4783-a5c2-ad8f4a6628dc")
	)
	(text "VDET is intended to\n differentiate between\n MPHB-001 and 002 connections\n based on the\n number of 5V\n inputs. This functionality\n is NOT used."
		(exclude_from_sim no)
		(at 166.37 83.566 0)
		(effects
